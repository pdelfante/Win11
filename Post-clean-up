# Alight start bar left
# Remove Printers
# Set timezone
# Turn sleep/hibernate off
# Start Windows updates

Set-ItemProperty -Path "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced" -Name "TaskbarAl" -Type DWord -Value 0

Get-Process explorer | Stop-Process

Get-Printer | Where-Object {$_.Name -notmatch "Microsoft|Fax|OneNote|PDF"} | Remove-Printer

Get-Printer | Remove-Printer

Set-TimeZone -Id "W. Australia Standard Time"

tzutil /s "W. Australia Standard Time"

powercfg /change standby-timeout-ac 0; powercfg /change standby-timeout-dc 0; powercfg /change hibernate-timeout-ac 0; powercfg /change hibernate-timeout-dc 0; powercfg /change monitor-timeout-ac 20; powercfg /change monitor-timeout-dc 15

usoclient StartScan

usoclient StartDownload

usoclient StartInteractiveScan
